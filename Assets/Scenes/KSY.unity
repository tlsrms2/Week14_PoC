  nextButton: {fileID: 2100001084}
  closeHelpButton: {fileID: 2100001104}
  helpPageImages:
  - {fileID: 1317057490}
  - {fileID: 754109857}
  - {fileID: 706867947}
  - {fileID: 880488901}
  helpPages:
  - "\uC774\uB3D9 - WASD\n\uB2EC\uB9AC\uAE30 - Shift\n\uACF5\uACA9 - \uC88C\uD074\uB9AD(\uD0C4\uD658
    \uC18C\uBAA8)\n\uBC29\uC5B4/\uC694\uACA9 - \uC6B0\uD074\uB9AD\n\uB77D\uC628 -
    Q\n\n\uD558\uB2E8 UI = <color=#32E658>\uCCB4\uB825</color> = <color=#FFA800>\uD0C4\uD658</color>"
  - "\uC801\uC774 \uBC1C\uC0AC\uD55C \uCD1D\uC54C\uC740 \uBC1C\uC0AC\uB41C \uC790\uB9AC\uC5D0\uC11C
    \n\uC7A0\uC2DC <u>\uB300\uAE30 \uC2DC\uAC04</u>\uC744 \uAC00\uC9D0\n\n<<color=#00BFFF>\uC694\uACA9</color>>\n\uC801
    \uCD1D\uC54C\uC774 \uB300\uAE30 \uC911\uC77C \uB54C \uC6B0\uD074\uB9AD\n<<color=#A4A4A4>\uBC29\uC5B4</color>>
    \n\uC801 \uCD1D\uC54C\uC774 \uD50C\uB808\uC774\uC5B4\uC5D0\uAC8C \uB0A0\uC544\uC62C
    \uB54C \uC6B0\uD074\uB9AD\n\n<color=#00BFFF>\uD328\uB9C1(\uC694\uACA9)</color>/<color=#A4A4A4>\uBC29\uC5B4</color>
    \uB294 <u>\uD30C\uB780\uC0C9 \uBC94\uC704</u> \uB0B4\n\uAC00\uAE4C\uC6B4 \uC21C\uC11C\uB85C
    \uBAA9\uD45C \uC9C0\uC815\n"
  - "<color=#00BFFF>\uC694\uACA9</color>: \uD50C\uB808\uC774\uC5B4 <color=#FFA800>\uD0C4\uD658</color>
    + 1 / \uC801 <color=#FFA800>\uD0C4\uD658</color> - 1\n\uBC29\uC5B4: \uD50C\uB808\uC774\uC5B4
    <color=#FFA800>\uD0C4\uD658</color> + 0 / \uC801 <color=#FFA800>\uD0C4\uD658</color>
    - 1\n\uB9DE\uAE30: \uD50C\uB808\uC774\uC5B4 <color=#FFA800>\uD0C4\uD658</color>
    - 1 / \uC801 <color=#FFA800>\uD0C4\uD658</color> + 0"
  - "<color=#FFA800>\uD0C4\uD658</color>\uC774 0\uC774 \uB418\uC5C8\uC744 \uB54C
    \uD53C\uACA9 \uB2F9\uD558\uBA74 \uC0AC\uB9DD\n\n\uC801\uC758 \uD0C4\uD658\uC774
    \uC5C6\uC744 \uB54C \uC88C\uD074\uB9AD\uC73C\uB85C <u>\uCC98\uD615 \uAC00\uB2A5</u>"
  gameOverRoot: {fileID: 2100001200}
  restartButton: {fileID: 2100001244}
